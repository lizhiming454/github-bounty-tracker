# GitHub Personal Access Token (fine-grained or classic)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of repos to scan (owner/repo format)
REPOS=nicehash/NiceHashQuickMiner,nicedoc/nicedoc.io

# Label names to search for bounties (comma-separated)
BOUNTY_LABELS=bounty,Bounty,💰 Bounty,help wanted

# Minimum bounty amount to show (USD, parsed from issue title/body)
MIN_AMOUNT=0

# Output format: table | json | csv
OUTPUT_FORMAT=table

# Scan interval in seconds when running in watch mode
WATCH_INTERVAL=300
